{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/stream",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/jobs/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/whatsapp/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/download",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 300
    }
  }
}